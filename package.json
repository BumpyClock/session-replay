{
  "name": "session-replay",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run vite",
    "dev:app": "bun run vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:server": "bun --watch server/dev.ts",
    "build": "bun run build:app",
    "build:app": "bun run tsc -b && bun run vite build",
    "build:server": "bun build ./server/index.ts --outdir dist/server --target bun",
    "preview": "bun run vite preview --host 127.0.0.1 --port 4173",
    "preview:app": "bun run vite preview --host 127.0.0.1 --port 4173",
    "lint": "bun run eslint .",
    "test": "bun run vitest run",
    "test:watch": "bun run vitest",
    "test:ui": "bun run vitest --ui"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "1.8.0",
    "markdown-it": "14.1.1",
    "motion": "^12.38.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "simple-icons": "^16.16.0",
    "zod": "^4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
